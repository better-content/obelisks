		{
			description: ["The Sand Filter is the Create-era continuous purification step. It improves water by one purity level and trades early manual boiling for fluid-handling infrastructure."]
			id: "68EF41C24DDBEA5F"
			tasks: [{
				id: "7D4B980DD02A9BEB"
				item: "thirst:sand_filter"
				type: "item"
			}]
			x: 2.5d
			y: -6.0d
		}
		{
			description: ["Fire a clay bowl into a reusable terracotta vessel before filling it. It is the simple early container for collecting, carrying, and heating small amounts of water."]
			id: "02FE7998B829DA0B"
			tasks: [{
				id: "18D5AAA11F4A073B"
				item: "thirst:terracotta_bowl"
				type: "item"
			}]
			x: 3.5d
			y: -6.0d
		}
		{
			description: ["A Campfire cooks food, boils supported water containers, and melts nearby snow blocks into water. It is the first dependable purification and cold-weather utility station."]
			id: "5BC604835B2CDEDA"
			tasks: [{
				id: "27616B009D034F05"
				item: "minecraft:campfire"
				type: "item"
			}]
			x: 2.5d
			y: -5.0d
		}
		{
			description: ["A bottle of water is only a container, not proof that the water is safe. Source and treatment determine purity, and dirty water can inflict nausea or poison."]
			id: "78BCBF9A4F3E0146"
			tasks: [{
				id: "334F3C1FA53F90CC"
				item: {
					Count: 1
					id: "minecraft:potion"
