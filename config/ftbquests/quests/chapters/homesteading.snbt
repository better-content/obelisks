				type: "item"
			}]
			x: 3.5d
			y: -5.0d
		}
		{
			description: ["An exposed Rain Collector stores up to four charges during rainfall. Drink from it or fill a supported container to turn weather into a renewable early-water reserve."]
			id: "E6A0291897193FB8"
			tasks: [{
				id: "876015D4D16F4251"
				item: "bcfixes:rain_collector"
				type: "item"
			}]
			x: 0.0d
			y: 0.0d
		}
		{
			description: ["The Waterskin is portable water and temperature support. Fill and purify it before travel, then use it for hydration or short-term thermal relief when conditions turn dangerous."]
			id: "06909084470EB7E9"
			tasks: [{
				id: "6FB3C592A35B7673"
				item: "cold_sweat:waterskin"
				type: "item"
			}]
			x: 0.0d
			y: 0.0d
		}
		{
			description: ["The Icebox chills a nearby sheltered area and can distribute cold through thermal paths. It is the household counterpart to the Boiler for hot climates."]
			id: "9C202A5FA69F0D77"
			tasks: [{
				id: "AEEC149BB119276A"
				item: "cold_sweat:icebox"
				type: "item"
			}]
			x: 0.0d
			y: 0.0d
		}
		{
			description: ["The Kettle brews Farmer's Respite teas and coffee while improving water purity through boiling. It connects hydration, crop variety, and useful food effects."]
			id: "4E189F50D436EFAD"
			tasks: [{
				id: "0D1258A7847B5358"
				item: "farmersrespite:kettle"
				type: "item"
			}]
			x: 0.0d
			y: 0.0d
		}
		{
			description: ["The Food Book tracks which foods you have eaten and makes culinary variety visible. Use it to find neglected ingredients instead of grinding one easy meal forever."]
			id: "010BF0BCB9DCD41A"
			tasks: [{
				id: "DDC04118117013A3"
				item: "solcarrot:food_book"
				type: "item"
			}]
			x: 0.0d
			y: 0.0d
		}
		{
			description: ["Combine dirt with biological waste, straw, and bone meal to start Organic Compost. Leave it to mature rather than expecting an instant finished soil block."]
			id: "CCDD7D4835CEB5EF"
			tasks: [{
				id: "C35F461D48547C11"
				item: "farmersdelight:organic_compost"
				type: "item"
			}]
			x: 0.0d
			y: 0.0d
		}
		{
			description: ["Organic Compost eventually matures into Rich Soil. Use it to establish productive permanent plots and as the base for rich-soil farmland."]
			id: "944D484E726EE5DE"
			tasks: [{
				id: "74F9A01D499138CB"
				item: "farmersdelight:rich_soil"
				type: "item"
			}]
			x: 0.0d
			y: 0.0d
		}
		{
			description: ["Tea bushes are specialty forage rather than ordinary Overworld groundcover. Find their starting stock through the Undergarden route, then cultivate a renewable supply at home."]
			id: "73F0931A5529071A"
			tasks: [{
				id: "95E2262B680EE19F"
				item: "farmersrespite:tea_seeds"
				type: "item"
			}]
			x: 0.0d
			y: 0.0d
		}
		{
			description: ["Coffee bushes are another Undergarden forage prize. Bring berries home for cultivation, roast the beans, and use the Kettle to turn them into a repeatable drink crop."]
			id: "D4AC62CFC37F4919"
			tasks: [{
				id: "885E68E880E3664D"
