	order_index: 1
	quest_links: [ ]
	quests: [
		{
			description: ["Goat fur provides cold insulation. Use it at the Sewing Table or wear goat-fur clothing when winter, altitude, or a frozen biome pushes body temperature down."]
			id: "17415831C5853554"
			tasks: [{
				id: "7F15080359BD18F6"
				item: "cold_sweat:goat_fur"
				type: "item"
			}]
			x: -1.0d
			y: -2.0d
		}
		{
			description: ["Hoglin hide provides heat insulation. It is the material to reach for when deserts, furnaces, or other hot environments overwhelm ordinary clothing."]
			id: "3C22313CCB65D488"
			tasks: [{
				id: "3F502189FEFF36D5"
				item: "cold_sweat:hoglin_hide"
				type: "item"
			}]
			x: -1.0d
			y: -1.0d
		}
		{
			description: ["Chameleon molt provides adaptive insulation, shifting between heat and cold protection as conditions change. Apply it when a route crosses several climates."]
			id: "01CF77C871D2865F"
			tasks: [{
				id: "0732A50FFC352D24"
				item: "cold_sweat:chameleon_molt"
				type: "item"
			}]
			x: -1.0d
			y: -4.0d
		}
		{
			description: ["The Soulspring Lamp suppresses extreme Nether heat while it has fuel. In this pack it only functions in the Nether, so it is expedition equipment rather than universal climate immunity."]
			id: "773C8C242A84D880"
			tasks: [{
				id: "73769B27C4EC5C32"
				item: {
					Count: 1
					id: "cold_sweat:soulspring_lamp"
					tag: {
						Fuel: 64.0d
					}
				}
				type: "item"
			}]
			x: -2.0d
			y: -1.0d
		}
		{
			description: ["Soul Sprouts are the pack-configured fuel for the Soulspring Lamp, and eating one provides a sustained cooling effect. Carry enough for the return journey instead of assuming one charge will cover an entire Nether expedition."]
			id: "3E50A898CF936716"
			tasks: [{
				id: "419E9F1212524D39"
				item: {
					Count: 1
					ForgeCaps: {
						"fiahi:food": { }
					}
					id: "cold_sweat:soul_sprout"
				}
				type: "item"
			}]
			x: -2.0d
			y: -2.0d
		}
		{
			description: ["Measure the climate before committing to a route or settlement site. Temperature changes with biome, elevation, season, time, weather, nearby blocks, and dimension."]
			id: "03A9C8A22386DD14"
			tasks: [{
				id: "6EB554D38C015A60"
				item: "cold_sweat:thermometer"
				type: "item"
			}]
			x: -2.0d
			y: -3.0d
		}
		{
			description: ["The Thermolith is a stationary climate instrument for monitoring conditions around the homestead. Use its readings when testing shelter and thermal equipment."]
			id: "08D1715923FBD755"
			tasks: [{
				id: "772DFC16CB1AEABC"
				item: "cold_sweat:thermolith"
				type: "item"
			}]
			x: -1.0d
			y: -3.0d
		}
		{
			description: ["A Hearth conditions a large sheltered area and can send its effect through connected paths. It is substantial Nether-gated infrastructure, not the first answer to a cold night."]
			id: "734FF52EDA7A1E85"
			tasks: [{
				id: "3CEB6097824B0E2E"
				item: "cold_sweat:hearth"
				type: "item"
			}]
			x: 0.0d
			y: -2.0d
		}
		{
			description: ["The Boiler warms a smaller nearby area. Fuel it deliberately and use it as household climate control when clothing alone is not enough."]
			id: "679E40E1720C4BE5"
			tasks: [{
				id: "6E1D7A4032F8756B"
				item: "cold_sweat:boiler"
				type: "item"
			}]
			x: 0.0d
			y: -3.0d
		}
		{
			description: ["Cold Sweat thermal sources need a Smokestack to distribute conditioned air. Build this as functional climate ducting, separate from the chimneys that vent pollution."]
			id: "3C57BC749410133B"
			tasks: [{
				id: "0EA922193244CDED"
				item: "cold_sweat:smokestack"
				type: "item"
			}]
			x: 0.0d
			y: -1.0d
		}
		{
			description: ["The Sewing Table installs insulating materials into wearable armour. Goat fur resists cold, hoglin hide resists heat, and chameleon molt adapts between them."]
			id: "53D1ECB1B7C43941"
			tasks: [{
				id: "4658D59CBF0FEB06"
				item: "cold_sweat:sewing_table"
				type: "item"
			}]
			x: 0.0d
			y: -4.0d
		}
		{
			description: ["Use the calendar to plan planting, fishing, travel, and winter preparation. Overworld crops grow slowly outside their fertile seasons instead of simply breaking."]
			id: "7FF7C82E11AAF3C1"
			tasks: [{
				id: "12D4B2B19DCE23A9"
				item: "sereneseasons:calendar"
				type: "item"
			}]
			x: -1.0d
			y: -6.5d
		}
		{
			description: ["A stone chimney gives smoke and machine emissions a route out of occupied spaces. Vent combustion instead of letting the homestead become its own environmental hazard."]
			id: "2170CAE3C4D056CA"
			tasks: [{
				id: "288DB78A21D52B7C"
				item: "adchimneys:stone_chimney"
				type: "item"
			}]
			x: -2.5d
			y: 2.0d
		}
		{
			description: ["Cobblestone provides an accessible chimney body for early workshops and kitchens. Route it above the roofline and keep the exhaust path clear."]
			id: "2330572303E1B157"
			tasks: [{
				id: "5632E7DC6303C226"
				item: "adchimneys:cobblestone_chimney"
				type: "item"
			}]
			x: -1.5d
			y: 2.0d
		}
		{
			description: ["Small brick chimneys are a compact masonry option for venting working buildings. The material changes the build, but the important lesson is to control where emissions leave it."]
			id: "690D649F22CB8168"
			tasks: [{
				id: "1144B7A202EC8BEE"
				item: "adchimneys:small_brick_chimney"
				type: "item"
			}]
			x: -0.5d
			y: 2.0d
		}
		{
			description: ["A large brick chimney makes the exhaust system an intentional part of a larger workshop. Use it where several combustion surfaces share the same industrial space."]
			id: "518AFB9EF61AC906"
			tasks: [{
				id: "2A94287E68E9ABFE"
				item: "adchimneys:large_brick_chimney"
				type: "item"
			}]
			x: 0.5d
			y: 2.0d
		}
		{
			description: ["The Starcatcher Rod opens a location- and season-sensitive fishing minigame. Fishing is a renewable food route, but the same catch will not be available everywhere or all year."]
			id: "35CD1117B47188CF"
			tasks: [{
				id: "6420A042E547AF11"
				item: "starcatcher:starcatcher_rod"
				type: "item"
			}]
			x: 4.5d
			y: 0.0d
		}
		{
			description: ["The Starcatcher Guide records the fish your team has discovered. Entries stay hidden until a fish is caught, so use it as a field journal rather than a complete answer key."]
			id: "310F6DC6A6BF0883"
			tasks: [{
				id: "6CF09234821726DA"
				item: "starcatcher:starcatcher_guide"
				type: "item"
			}]
			x: 5.5d
			y: 0.0d
		}
		{
			description: ["The Keg ferments drinks and preserves foods. Start with sufficiently clean liquid: poorly purified fermentation can grow bacteria and make the result dirtier."]
			id: "535700C7748FB081"
			tasks: [{
				id: "524698E90B02597A"
				item: "brewinandchewin:keg"
				type: "item"
			}]
			x: -9.0d
			y: 1.0d
		}
		{
			description: ["The Stove is the permanent heat source for Farmer's Delight cookware. It also belongs to the pack's emissions surface, so plan kitchen ventilation with it."]
			id: "23BED615533CD349"
			tasks: [{
				id: "1E83E0E3BDFA95E6"
				item: "farmersdelight:stove"
				type: "item"
			}]
			x: -8.0d
			y: -3.5d
		}
		{
			description: ["The Cooking Pot turns several ingredients into efficient meals, stews, and processed extracts. It is where a varied pantry starts becoming sustained working time."]
			id: "0350BBF8A26EDE29"
			tasks: [{
				id: "68BDA367A4545DAE"
				item: "farmersdelight:cooking_pot"
				type: "item"
			}]
			x: -8.0d
			y: -4.5d
		}
		{
			description: ["The Skillet cooks individual foods directly over heat and remains useful away from the full kitchen. Use it for quick preparation while the pot handles larger recipes."]
			id: "28053EF5D81A77BE"
			tasks: [{
				id: "66FDBA3DAFC546BB"
