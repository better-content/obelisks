			x: -8.0d
			y: -5.5d
		}
		{
			description: ["Place ingredients on the Cutting Board and work them with a knife to obtain cuts, portions, and useful byproducts. Many pack-authored food reagents begin here."]
			id: "16758DFB0A034701"
			tasks: [{
				id: "0BDA4931A4046F4B"
				item: "farmersdelight:cutting_board"
				type: "item"
			}]
			x: -8.0d
			y: -2.5d
		}
